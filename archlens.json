{
    "$schema": "https://raw.githubusercontent.com/archlens/ArchLens/master/src/python/src/config.schema.json",
    "name": "Archlens",
    "rootFolder": "src/c-sharp/",
    "github": {
        "url": "https://github.com/archlens/ArchLens",
        "branch": "master"
    },
    "snapshotDir": ".archlens",
    "snapshotFile": "snapshot",
    "saveLocation": "./diagrams/",
    "exclusions": [
        "obj/",
        "bin/",
        ".vs/",
        ".git/",
        ".idea/",
        ".archlens"
    ],
    "fileExtensions": [
        ".cs"
    ],
    "views": {
        "completeView": {
            "packages": [],
            "ignorePackages": [
                "diagrams",
                "venv"
            ]
        }
    }
}